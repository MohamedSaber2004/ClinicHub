<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath=".\ClinicHub.API.exe" stdoutLogEnabled="true" stdoutLogFile=".\Logs\stdout" hostingModel="InProcess" startupTimeLimit="300" requestTimeout="00:05:00">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Test" />
      </environmentVariables>
    </aspNetCore>
  </system.webServer>
</configuration>